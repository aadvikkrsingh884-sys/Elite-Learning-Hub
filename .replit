modules = ["nodejs-20", "web", "bash", "python-base-3.13", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[objectStorage]
defaultBucketID = "replit-objstore-5845706a-c7fc-4321-aba5-d9a8b6a7d78b"

[userenv]

[userenv.shared]
VITE_GOOGLE_CLIENT_ID = "258473449298-g6hmnlhjfmflkrgmsr8o02lrb8jh0nf8.apps.googleusercontent.com"
RESEND_FROM_EMAIL = "onboarding@resend.dev"
